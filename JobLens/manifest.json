{
  "manifest_version": 3,
  "name": "JobLens",
  "description": "Analiza las ofertas de empleo y calcula la compatibilidad.",
  "version": "1.0.0",
  "author": "AndresSTW (Axion Studios)",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.computrabajo.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "JobLens"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "css": [
        "ui/overlay.css"
      ],
      "js": [
        "ui/overlay.js",
        "content/linkedin.js"
      ]
    },
    {
      "matches": [
        "https://www.computrabajo.com/*"
      ],
      "css": [
        "ui/overlay.css"
      ],
      "js": [
        "ui/overlay.js",
        "content/computrabajo.js"
      ]
    }
  ]
}